POSTGRES_DB=EventosVivosDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
FRONTEND_ORIGIN=http://localhost:4200

# Puertos publicados en el host (cambialos si ya tienes algo corriendo en 5433/8081/8088)
POSTGRES_PORT=5433
API_PORT=8081
KEYCLOAK_PORT=8088
FRONT_PORT=4200

# Keycloak (admin de la consola y secreto del cliente del API)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_CLIENT_SECRET=eventosvivos-api-secret-dev
